
# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_DB_URL=

# ── Tool APIs ─────────────────────────────────────────────
FIRECRAWL_API_KEY=
SERPAPI_KEY=

# ── Scrape.do (free 1000 req/month — anti-bot fallback) ──
# Sign up free at https://scrape.do → Dashboard → copy token
SCRAPE_DO_TOKEN=

# ── Vertex AI (Google Cloud) ──────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_GEMINI_MODEL=
VERTEX_EMBEDDING_MODEL=

# Legacy AI Studio key (no longer used — Vertex uses service account / ADC)
# GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=

# ── Legacy (no longer used) ───────────────────────────────
# HUGGING_FACE_API_KEY=your_hugging_face_api_key
# HUGGING_FACE_MODEL=Qwen/Qwen3-32B
# HUGGING_FACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Optional (Reddit public JSON API works without keys) ──
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Optional (Meta Ad Library uses Firecrawl scrape, no token needed) ──
META_ADS_TOKEN=

# ── MiroFish Synthetic (existing VPS 167.71.230.193) ──────
# Run: npx tsx scripts/mirofish-bootstrap.ts  (pointed at MIROFISH_BASE_URL)
MIROFISH_BASE_URL=


# ── MiroFish Live (real VPS 168.144.36.78) ────────────────
# 1. SSH: place Groq+Zep in /opt/mirofish/.env, docker compose up -d
# 2. Run: MIROFISH_BASE_URL=http://168.144.36.78:5001 npx tsx scripts/mirofish-bootstrap-auto.ts "Product" scripts/seeds/vector-agents.txt
#    (On free Groq tier, seed is auto-trimmed; override with MIROFISH_ONTOLOGY_MAX_BYTES if needed.)
# 3. Paste the printed line below. Example shape:
MIROFISH_LIVE_BASE_URL=

# Optional fallback when product extraction is ambiguous/unset:
# MIROFISH_LIVE_DEFAULT_SIMULATION_ID=sim_xxx

WEATHER_API_KEY=
NEWS_API_KEY=

# Optional — not used by PlanGro core (Groq was fallback; app uses Vertex AI)
# Groq_api_key=
